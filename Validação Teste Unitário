java
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;

public class ValidadorUsuarioTest {

    private ValidadorUsuario validador;

    @BeforeEach
    void setUp() {
        validador = new ValidadorUsuario();
    }

    // TESTES - NOME DE USUÁRIO

    @Test
    void deveRetornarTrueParaNomeValido() {
        assertTrue(validador.validarNomeUsuario("Gabriel"));
    }

    @Test
    void deveRetornarFalseParaNomeMuitoCurto() {
        assertFalse(validador.validarNomeUsuario("Ga"));
    }

    @Test
    void deveRetornarFalseParaNomeMuitoLongo() {
        assertFalse(validador.validarNomeUsuario("NomeExtremamenteGrande"));
    }

    @Test
    void deveRetornarFalseParaNomeNulo() {
        assertFalse(validador.validarNomeUsuario(null));
    }

    @Test
    void deveAceitarNomeComTamanhoMinimo() {
        assertTrue(validador.validarNomeUsuario("Leo")); // 3 caracteres
    }

    @Test
    void deveAceitarNomeComTamanhoMaximo() {
        assertTrue(validador.validarNomeUsuario("NomeGrande")); // 20 caracteres
    }

    // TESTES - EMAIL

    @Test
    void deveRetornarTrueParaEmailValido() {
        assertTrue(validador.validarEmail("teste@email.com"));
    }

    @Test
    void deveRetornarFalseParaEmailSemArroba() {
        assertFalse(validador.validarEmail("testeemail.com"));
    }

    @Test
    void deveRetornarFalseParaEmailSemDominio() {
        assertFalse(validador.validarEmail("teste@"));
    }

    @Test
    void deveRetornarFalseParaEmailNulo() {
        assertFalse(validador.validarEmail(null));
    }

    @Test
    void deveAceitarEmailComSubdominio() {
        assertTrue(validador.validarEmail("user@mail.com.br"));
    }

    @Test
    void deveRejeitarEmailComFormatoInvalido() {
        assertFalse(validador.validarEmail("user@.com"));
    }

    // TESTES - SENHA

    @Test
    void deveRetornarTrueParaSenhaValida() {
        assertTrue(validador.validarSenha("abece12345"));
    }

    @Test
    void deveRetornarFalseParaSenhaMuitoCurta() {
        assertFalse(validador.validarSenha("ab12"));
    }

    @Test
    void deveRetornarFalseParaSenhaSemNumeros() {
        assertFalse(validador.validarSenha("abecedeeefigeaga"));
    }

    @Test
    void deveRetornarFalseParaSenhaSemLetras() {
        assertFalse(validador.validarSenha("12345678"));
    }

    @Test
    void deveRetornarFalseParaSenhaNula() {
        assertFalse(validador.validarSenha(null));
    }

    @Test
    void deveAceitarSenhaComLetrasEMumerosNoLimite() {
        assertTrue(validador.validarSenha("a1b2c3d4")); // 8 caracteres
    }

    @Test
    void deveRejeitarSenhaComApenasCaracteresEspeciais() {
        assertFalse(validador.validarSenha("$$$$$$"));
    }
}

